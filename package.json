    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.40.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
