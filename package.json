    "evaluate:slo-bundle": "./scripts/evaluate-slo-bundle.sh",
    "verify:observability-slo-bundle": "./scripts/verify-observability-slo-bundle.sh",
    "verify:dashboard-slo-export": "./scripts/verify-dashboard-slo-export.sh",
    "evaluate:alert-rules": "./scripts/evaluate-alert-rules.sh",
    "verify:observability-alerts": "./scripts/verify-observability-alerts.sh",
    "verify:plugin-failover-recovery": "./scripts/verify-plugin-failover-recovery.sh",
    "verify:incident-ui": "./scripts/verify-incident-ui.sh",
    "verify:security-rotation": "./scripts/verify-security-rotation.sh",
    "verify:release-pipeline": "./scripts/verify-release-pipeline.sh",
    "verify:release-candidate": "./scripts/verify-release-candidate.sh",
    "verify:release-traceability": "./scripts/verify-release-traceability.sh",
    "release:candidate": "./scripts/release-candidate-professional.sh",
    "verify:runbooks-dr": "./scripts/verify-runbooks-dr.sh",
    "verify:cycle2-regression": "./scripts/verify-cycle2-regression.sh",
