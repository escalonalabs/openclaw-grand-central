    "verify:dr-integrity": "./scripts/verify-dr-integrity.sh",
    "verify:dr-drill": "./scripts/verify-dr-drill.sh",
    "verify:lane-fairness": "./scripts/verify-lane-fairness.sh",
    "verify:action-idempotency": "./scripts/verify-action-idempotency.sh",
    "verify:policy-pack-rollback": "./scripts/verify-policy-pack-rollback.sh",
    "verify:operational-timeline-ui": "./scripts/verify-operational-timeline-ui.sh",
    "benchmark:synthetic-load": "./scripts/run-synthetic-load-benchmark.sh",
    "verify:synthetic-load-budgets": "./scripts/verify-synthetic-load-budgets.sh",
    "verify:synthetic-load": "./scripts/verify-synthetic-load.sh",
